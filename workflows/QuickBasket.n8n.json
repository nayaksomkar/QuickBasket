        "jsCode": "let output = $input.first().json.output || \"\";\n\nif (typeof output !== \"string\") {\n  output = JSON.stringify(output);\n}\n\n// Remove markdown + unwanted characters\noutput = output\n  .replace(/```json/g, '')\n  .replace(/```/g, '')\n  .replace(/^[^\\{]*/, '')\n  .replace(/[^\\}]*$/, '')\n  .replace(/[\\u0000-\\u001F]+/g, '') // remove control characters\n  .trim();\n\nconst data = JSON.parse(output);\n\nconst record = {\n  raw: data,\n  message: $('Message_received').first().json.message,\n  timestamp: new Date()\n};\n\nreturn [\n  {\n    json: record\n  }\n];"
      },
