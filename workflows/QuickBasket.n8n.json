    {
      "parameters": {
        "jsCode": "const rows = $input.all();\n\nlet grand_total = 0;\n\nconst items = rows.map(i => {\n  const price = i.json.price;\n  const qty = i.json.total_quantity;\n  const total = i.json.total_price;\n\n  grand_total += total;\n\n  return {\n    \"Product\": i.json.item_name,\n    \"Quantity\": qty,\n    \"Unit Price\": `INR ${price}`,\n    \"Total\": `INR ${price} × ${qty}  (INR ${total})`\n  };\n});\n\nreturn [\n  {\n    json: {\n      items,\n      \"Grand Total\": `INR ${grand_total}`\n    }\n  }\n];"
      },
