    {
      "parameters": {
        "jsCode": "let ObjectItems = {};\n\nconst ObjectListis = $json.ObjectListis;\n\nif (!ObjectListis || ObjectListis === \"new\") {\n  const allItems = $('Raw data').all();\n\n  for (const item of allItems) {\n    const orderItems = item.json?.raw?.items || {};\n\n    for (const [name, quantity] of Object.entries(orderItems)) {\n      ObjectItems[name] = (ObjectItems[name] || 0) + quantity;\n    }\n  }\n\n} else {\n  ObjectItems = $json.ObjectItems || {};\n}\n\nconst items = Object.entries(ObjectItems).map(([name, quantity]) => ({\n  [name]: quantity\n}));\n\nreturn [\n  {\n    json: {\n      items\n    }\n  }\n];"
      },
