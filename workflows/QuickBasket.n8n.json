    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT \n    t.item_name,\n    t.total_quantity,\n    COALESCE(p.price,0) as price,\n    (t.total_quantity * COALESCE(p.price,0)) AS total_price\nFROM temp_orders t\nLEFT JOIN products p \nON LOWER(t.item_name) = LOWER(p.name);",
        "options": {}
